<Window x:Class="AltRunSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AltRunSharp" Height="60" Width="620"
        MinHeight="60"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="Height"
        Icon="pack://application:,,,/icon.ico"
        Loaded="Window_Loaded">
    <Border x:Name="RootBorder" CornerRadius="12"
            Background="#1E1E2E"
            BorderBrush="#45475A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Input row -->
            <Grid Grid.Row="0" Margin="14,0,14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Search icon -->
                <TextBlock Grid.Column="0" Text="⌕" Foreground="#6C7086"
                           FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <!-- Input box -->
                <TextBox x:Name="InputTextBox"
                         Grid.Column="1"
                         FontSize="18"
                         FontFamily="'Segoe UI', sans-serif"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#CDD6F4"
                         CaretBrush="#CBA6F7"
                         VerticalAlignment="Center"
                         TextChanged="InputTextBox_TextChanged"/>
            </Grid>

            <!-- Separator (visible when list is shown) -->
            <Rectangle Grid.Row="1" x:Name="Separator"
                       Height="1" Fill="#313244"
                       Visibility="Collapsed"/>

            <!-- Results list -->
            <ListBox x:Name="ResultsList"
                     Grid.Row="1"
                     Background="Transparent"
                     BorderThickness="0"
                     Focusable="False"
                     Visibility="Collapsed"
                     MaxHeight="300"
                     Margin="0,0,0,8"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource ResultItemStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="14,5,14,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#CDD6F4"
                                           FontSize="14"
                                           FontFamily="'Segoe UI', sans-serif"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}"
                                           Foreground="#6C7086"
                                           FontSize="12"
                                           FontFamily="'Segoe UI', sans-serif"
                                           Visibility="{Binding Description, Converter={StaticResource StringVisibilityConverter}}"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#313244" CornerRadius="4"
                                    Padding="6,2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding KindLabel}"
                                           Foreground="#89B4FA"
                                           FontSize="11"
                                           FontFamily="'Segoe UI', sans-serif"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
