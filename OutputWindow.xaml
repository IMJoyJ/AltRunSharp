<Window x:Class="AltRunSharp.OutputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AltRunSharp - 输出" Height="420" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Icon="pack://application:,,,/icon.ico">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#2A2A3E" Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Fill="#FF5F57" Margin="0,0,6,0"/>
                <Ellipse Width="10" Height="10" Fill="#FFBD2E" Margin="0,0,6,0"/>
                <Ellipse Width="10" Height="10" Fill="#27C93F" Margin="0,0,12,0"/>
                <TextBlock x:Name="TitleLabel" Text="输出" Foreground="#CDD6F4"
                           FontFamily="Consolas, 'Courier New', monospace" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Output area -->
        <ScrollViewer x:Name="OutputScroll" Grid.Row="1"
                      Background="#1E1E2E"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Padding="4,0">
            <TextBlock x:Name="OutputText"
                       FontFamily="Consolas, 'Courier New', monospace"
                       FontSize="13"
                       Foreground="#CDD6F4"
                       Background="Transparent"
                       TextWrapping="NoWrap"
                       Padding="10,8"/>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#181825" Padding="14,6">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#A6E3A1" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusLabel" Text="运行中..." Foreground="#6C7086"
                           FontFamily="Consolas, 'Courier New', monospace" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
